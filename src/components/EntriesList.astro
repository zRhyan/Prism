---
// src/components/EntriesList.astro
// Frontmatter runs on the server (Node.js) — no localStorage here.
// Table is populated entirely by the client-side <script> below.
---

<div class="entries-box">
  <h2>📖 All Entries</h2>

  <table id="entries-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Parameter</th>
        <th>Period</th>
        <th>Rating</th>
        <th>Duration</th>
        <th>Comment</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <div class="entries-actions">
    <button id="export-storage" class="export-btn">Export JSON</button>
    <button id="export-csv"     class="export-btn">Export CSV</button>
    <button id="reset-storage"  class="reset-btn">Reset Storage</button>
  </div>
</div>

<script>
  import { getEntries, resetStorage, localDateStr } from '../scripts/storage.js';

  const tbody = document.querySelector('#entries-table tbody');

  const entries = getEntries().sort((a, b) => {
    if (b.date !== a.date) return b.date.localeCompare(a.date);
    const order = { morning: 0, afternoon: 1 };
    const pa = order[a.period] ?? 2;
    const pb = order[b.period] ?? 2;
    if (pb !== pa) return pb - pa;
    return new Date(b.createdAt) - new Date(a.createdAt);
  });

  // Fix: build rows via DOM to avoid XSS from user-supplied fields
  entries.forEach((e) => {
    const [year, month, day] = e.date.split('-').map(Number);
    const localDate = new Date(year, month - 1, day);

    const td = (text) => {
      const cell = document.createElement('td');
      cell.textContent = text;
      return cell;
    };

    const tr = document.createElement('tr');
    tr.appendChild(td(localDate.toLocaleDateString()));
    tr.appendChild(td(e.parameterName || '—'));
    tr.appendChild(td(e.period));
    tr.appendChild(td(String(e.rating)));
    tr.appendChild(td(e.duration != null ? `${e.duration} min` : '—'));
    tr.appendChild(td(e.comment || '—'));
    tbody.appendChild(tr);
  });

  // ── Reset ────────────────────────────────────────────────────────────────────
  document.getElementById('reset-storage').onclick = () => {
    if (confirm('Delete ALL parameters and entries? This cannot be undone.')) {
      resetStorage();
      location.reload();
    }
  };

  // ── Export JSON ──────────────────────────────────────────────────────────────
  document.getElementById('export-storage').onclick = () => {
    const data = {};
    for (const key of Object.keys(localStorage)) {
      try        { data[key] = JSON.parse(localStorage.getItem(key)); }
      catch (_)  { data[key] = localStorage.getItem(key); }
    }
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = 'prism-data.json';
    a.click();
    URL.revokeObjectURL(url);
  };

  // ── Export CSV ───────────────────────────────────────────────────────────────
  document.getElementById('export-csv').onclick = () => {
    const csv_entries = getEntries().sort((a, b) => a.date.localeCompare(b.date));

    const escape = (v) => `"${String(v ?? '').replace(/"/g, '""')}"`;

    const header = ['id', 'date', 'period', 'parameter', 'rating', 'duration_min', 'comment', 'createdAt'].join(',');
    const rows   = csv_entries.map(e => [
      e.id,
      e.date,
      e.period,
      escape(e.parameterName),
      e.rating,
      e.duration ?? '',     // empty string = not recorded, distinct from 0
      escape(e.comment),
      e.createdAt,
    ].join(','));

    const csv  = [header, ...rows].join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = `prism-${localDateStr(new Date())}.csv`;
    a.click();
    URL.revokeObjectURL(url);
  };
</script>