---
// src/components/EntriesList.astro
import { getEntries } from "../scripts/storage.js";

const entries = getEntries().sort(
  (a, b) => new Date(b.createdAt) - new Date(a.createdAt)
);
---

<div class="entries-box">
  <h2>📖 All Entries</h2>
  <table id="entries-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Parameter</th>
        <th>Rating</th>
        <th>Comment</th>
      </tr>
    </thead>
    <tbody></tbody>
  </table>

  <!-- Div necessária para deixar os dois botões na parte inferior do container. -->
  <!-- O CSS dessa div empurra para baixo e coloca um em cada linha -->
  <div class="entries-actions">
    <!-- Export data button -->
    <button id="export-storage" class="export-btn">Export Data</button>
    <!-- Reset button at bottom -->
    <button id="reset-storage" class="reset-btn">Reset Storage</button>
  </div>


</div>

<script>
  import { getEntries, resetAll } from "../scripts/storage.js";

  const tbody = document.querySelector("#entries-table tbody");
  const entries = getEntries();

  entries.forEach(e => {
    const row = document.createElement("tr");
    row.innerHTML = `
      <td>${new Date(e.date).toLocaleDateString()}</td>
      <td>${e.parameterName}</td>
      <td>${e.rating}</td>
      <td>${e.comment || "—"}</td>
    `;
    tbody.appendChild(row);
  });

  // reset storage
  document.getElementById("reset-storage").onclick = () => {
    if (confirm("Delete ALL parameters and entries? This cannot be undone.")) {
      resetAll();
      location.reload();
    }
  };

  // export data
  document.getElementById("export-storage").onclick = () => {
    const data = {}; 
    for (const key of Object.keys(localStorage)) {
      try {
        data[key] = JSON.parse(localStorage.getItem(key));
      } catch {
        data[key] = localStorage.getItem(key);
      }
    }

    const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "prism-data.json";
    a.click();
  };

</script>
